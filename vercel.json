{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/)(?!assets/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/invoice/cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/amazon/cron/sync",
      "schedule": "0 */3 * * *"
    }
  ]
}
