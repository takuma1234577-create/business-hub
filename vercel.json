{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/index.js": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/)(?!assets/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/daily-cron",
      "schedule": "*/15 * * * *"
    }
  ]
}
